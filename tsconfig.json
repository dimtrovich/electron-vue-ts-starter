{
	"include": ["env.d.ts", "src/**/*", "src/**/*.ts",  "src/**/*.d.ts",  "src/**/*.vue"],
	"compilerOptions": {
		// Include Node.js types and avoid accidentally including other `@types/*` packages.
		"types": ["node"],

		"paths": {
			"@/*": ["./src/renderer/*"],
			"#/*": ["./src/shared/*"],
		},
    }
}
